{
  "name": "@mongrov/theme",
  "version": "0.1.0",
  "description": "Theme contract and color scheme management for React Native / Expo apps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mongrov/mongrov-packages.git",
    "directory": "packages/theme"
  },
  "keywords": [
    "react-native",
    "expo",
    "theme",
    "dark-mode",
    "color-scheme",
    "design-tokens"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./navigation": {
      "types": "./dist/navigation-theme.d.ts",
      "import": "./dist/navigation-theme.js",
      "default": "./dist/navigation-theme.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74",
    "zustand": ">=5",
    "react-native-mmkv": ">=3"
  },
  "peerDependenciesMeta": {
    "react-native-mmkv": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "react-native": "^0.74.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3",
    "zustand": "^5.0.10"
  }
}
