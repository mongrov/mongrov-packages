{
  "name": "@mongrov/ai",
  "version": "0.1.0",
  "description": "AI chat and completion hooks for React Native / Expo — XState-powered with AI SDK integration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mongrov/mongrov-packages.git",
    "directory": "packages/ai"
  },
  "keywords": [
    "react-native",
    "expo",
    "ai",
    "chat",
    "streaming",
    "xstate",
    "ai-sdk"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "xstate": "^5.19.0",
    "@xstate/react": "^5.0.0"
  },
  "peerDependencies": {
    "ai": ">=4",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-gifted-chat": ">=2",
    "uniwind": ">=1"
  },
  "peerDependenciesMeta": {
    "react-native-gifted-chat": {
      "optional": true
    },
    "uniwind": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "ai": "^4.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "react-native": "^0.74.0",
    "react-test-renderer": "^18.2.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3",
    "uniwind": "^1.6.1"
  }
}
