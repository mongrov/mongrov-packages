{
  "name": "@mongrov/core",
  "version": "0.4.0",
  "description": "Structured logging for React Native / Expo — ring buffer, file, and webhook transports with offline queue. Includes dev-tools UI components.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mongrov/mongrov-packages.git",
    "directory": "packages/core"
  },
  "keywords": [
    "react-native",
    "expo",
    "logging",
    "structured-logging",
    "ring-buffer",
    "webhook",
    "offline-queue",
    "dev-tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "expo-file-system": ">=17",
    "expo-network": ">=6",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-mmkv": ">=3",
    "expo-router": ">=4",
    "uniwind": ">=1"
  },
  "peerDependenciesMeta": {
    "expo-file-system": {
      "optional": true
    },
    "expo-network": {
      "optional": true
    },
    "react-native-mmkv": {
      "optional": true
    },
    "expo-router": {
      "optional": true
    },
    "uniwind": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "react-native": "^0.74.0",
    "react-test-renderer": "^18.2.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3",
    "uniwind": "^1.6.1"
  }
}
